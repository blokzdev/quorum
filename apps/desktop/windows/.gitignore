flutter/ephemeral/

# The Flutter runner manifest is a real BUILD SOURCE (referenced by runner/CMakeLists.txt), but the
# root .gitignore's generic `*.manifest` (a Python-artifact pattern) swallows it — un-ignore it, or a
# clean checkout / CI can't `flutter build windows` ("Cannot find source file: runner.exe.manifest").
!runner/runner.exe.manifest

# Visual Studio user-specific files.
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio build-related files.
x64/
x86/

# Visual Studio cache files
# files ending in .cache can be ignored
*.[Cc]ache
# but keep track of directories ending in .cache
!*.[Cc]ache/
